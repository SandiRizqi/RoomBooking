{
    "version": 2,
    "framework": null,
   "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.8.0"
    }
  },
  "routes": [
    { "src": "/build/(.*)", "dest": "/public/build/$1" },
    { "src": "/assets/(.*)", "dest": "/public/assets/$1" },
    { "src": "/css/(.*)", "dest": "/public/css/$1" },
    { "src": "/js/(.*)", "dest": "/public/js/$1" },
    { "src": "/favicon.ico", "dest": "/public/favicon.ico" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ],
  "installCommand": "composer install --no-dev --optimize-autoloader",
  "buildCommand": "php artisan config:cache && php artisan route:cache && php artisan view:cache && php artisan event:cache && npm run build",
    "outputDirectory": "public",
    "env": {
        "APP_ENV": "production"
    }
}
